  "query": "SELECT label_id, address, kind, value, confidence, source, source_detail,\n                      created_at, valid_until\n               FROM labels\n               WHERE address = $1\n                 AND revoked_at IS NULL\n                 AND created_at <= $2\n                 AND (valid_until IS NULL OR valid_until > $2)\n               ORDER BY created_at, label_id",
