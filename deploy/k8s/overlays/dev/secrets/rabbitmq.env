# DEV ONLY. The default vhost "/" MUST be percent-encoded as %2f in the URL —
# a bare trailing slash is the *empty* vhost and the broker rejects it.
RABBITMQ_DEFAULT_USER=mev
RABBITMQ_DEFAULT_PASS=changeme_rabbitmq_password
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_URL=amqp://mev:changeme_rabbitmq_password@rabbitmq:5672/%2f
