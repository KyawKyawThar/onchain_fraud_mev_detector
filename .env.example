# Template for `.env` (which is gitignored). Copy it and you're ready for the
# local docker-compose stack:
#
#     cp .env.example .env && just up
#
# The `changeme_*` values are the local dev defaults the compose services read —
# fine for a laptop, NEVER for staging/production. Rotate every secret per
# environment (generate strong values, e.g. `openssl rand -base64 48`).

# ── App ─────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
LOG_LEVEL=debug              # debug | info | warn | error
LOG_FORMAT=pretty            # pretty | json


# ── Server ──────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# How many seconds before an idle HTTP connection is closed
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s

# Max WebSocket connections per server instance (WS /v1/stream, §11)
WS_MAX_CONNECTIONS_PER_SERVER=1000

# Where `server` (this is the §11 API service binary) reaches the internal
# services it fronts: event-store's and simulation-projection's internal read
# APIs (HTTP) and intelligence's `IntelligenceRead` service (gRPC).
EVENT_STORE_URL=http://127.0.0.1:8081
SIMULATION_URL=http://127.0.0.1:8082
INTELLIGENCE_GRPC_ADDR=http://127.0.0.1:50051


# ── PostgreSQL (in-flight jobs, incidents, labels/entities) ─────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mev
POSTGRES_USER=mev
POSTGRES_PASSWORD=changeme_postgres_password

# Full DSN (used by services directly; compose overrides with internal hostname)
DATABASE_URL=postgres://mev:changeme_postgres_password@127.0.0.1:5432/mev?sslmode=disable

# Connection pool
DB_POOL_MAX_CONNS=25
DB_POOL_MIN_CONNS=5
DB_POOL_MAX_CONN_LIFETIME=1h
DB_POOL_MAX_CONN_IDLE_TIME=30m


# ── Redis (hot cache + risk-score cache, §8.3) ──────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0
REDIS_MAXMEMORY=256mb

# Full URL (compose overrides with internal hostname)
REDIS_URL=redis://:changeme_redis_password@127.0.0.1:6379/0


# ── ClickHouse (event store + analytics, §14) ───────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9001          # host port; native protocol is 9000 inside the container
CLICKHOUSE_DB=mev
CLICKHOUSE_USER=mev
CLICKHOUSE_PASSWORD=changeme_clickhouse_password

# Full URL (compose overrides with internal hostname:9000)
CLICKHOUSE_URL=http://mev:changeme_clickhouse_password@127.0.0.1:8123/mev
# Credential-free HTTP base for the `clickhouse` Rust client (user/password/db
# are passed separately, from the vars above). Compose overrides the host.
CLICKHOUSE_HTTP_URL=http://127.0.0.1:8123


# ── Event-store service (§4) ────────────────────────────────────
# Internal HTTP append API bind address.
EVENT_STORE_HOST=0.0.0.0
EVENT_STORE_PORT=8081
# Shared secret internal callers present as `Authorization: Bearer <token>`.
# Distinct from the public JWT below; rotate per environment.
EVENT_STORE_WRITE_TOKEN=changeme_event_store_internal_write_token
# Kafka consumer group — restarts resume from committed offsets.
EVENT_STORE_KAFKA_GROUP=event-store
# Topology the event-store provisions on boot (§20): one topic per event type,
# partitioned by chain. Partitions are the per-chain parallelism/capacity
# ceiling (chain is the message key); replication is 1 for the single local
# broker. Retention bounds the wire (§2/§4 — Kafka is the wire, not the record;
# ClickHouse is the permanent log), so it must be positive (never -1/infinite).
# All optional — these defaults (3 / 1 / 7 days) apply when unset.
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=1
KAFKA_RETENTION_MS=604800000


# ── simulation-projection internal read API (§11) ────────────────
# `GET /v1/incidents` bind address — fronted by the public API service below,
# same posture as EVENT_STORE_HOST/PORT.
SIMULATION_PROJECTION_HTTP_HOST=0.0.0.0
SIMULATION_PROJECTION_HTTP_PORT=8082


# ── intelligence gRPC read API (§11) ──────────────────────────────
# `IntelligenceRead` (GetRiskScore/GetLabels) bind address — the `intelligence
# grpc` run mode.
INTELLIGENCE_GRPC_HOST=0.0.0.0
INTELLIGENCE_GRPC_PORT=50051


# ── RabbitMQ (simulation sim.jobs work queue, §7) ───────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
# Image-native names (read directly by the rabbitmq container)
RABBITMQ_DEFAULT_USER=mev
RABBITMQ_DEFAULT_PASS=changeme_rabbitmq_password
RABBITMQ_DEFAULT_VHOST=/

# Full AMQP URL (compose overrides with internal hostname). The default vhost "/"
# MUST be percent-encoded as %2f — a bare trailing slash means the *empty* vhost
# ("") and the broker rejects it with "vhost not found".
RABBITMQ_URL=amqp://mev:changeme_rabbitmq_password@127.0.0.1:5672/%2f

# Queue topology (§7): durable quorum queue + dead-letter exchange/queue.
RABBITMQ_SIM_QUEUE=sim.jobs
RABBITMQ_SIM_DLX=sim.jobs.dlx
# Quarantine queue bound behind the DLX where jobs land after exhausting retries.
RABBITMQ_SIM_DLQ=sim.jobs.dlq
# Quorum-queue redelivery cap: after this many failed deliveries a job dead-letters
# to the DLX instead of looping forever (§7 "fails N times").
RABBITMQ_SIM_DELIVERY_LIMIT=5


# ── Kafka (domain event backbone, §2/§4) ────────────────────────
# App-facing connection string.
#   - From the host (tests, local binaries):   localhost:9092
#   - From inside another compose container:    kafka:29092  (INTERNAL listener)
KAFKA_BROKERS=localhost:9092
KAFKA_INTERNAL_BROKERS=kafka:29092

# Broker config (consumed by the kafka service in docker-compose)
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092,INTERNAL://kafka:29092
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,INTERNAL://0.0.0.0:29092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,INTERNAL:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_NUM_PARTITIONS=3


# ── Chain source adapter (RPC failover pool, §5 / Sprint 2) ─────
# Comma-separated RPC endpoints in preference order; the pool tries them
# first-to-last, health-checks each, and circuit-breaks a failing one out of
# rotation (adapter #3). REQUIRED for the ingestion service to start.
# ETH_RPC_URLS=https://eth.example/key1,https://eth-backup.example/key2
# ETH_WS_URL — for the node-IPC newHeads adapter (#2), deferred to Phase 8.
# ETH_WS_URL=wss://eth.example/ws/key1
CHAIN_ID=1
FINALIZATION_DEPTH=64            # blocks before a block is treated as final (§15)
FINALIZE_INTERVAL_MS=12000       # how often the pipeline polls the `finalized` tag → BlockFinalized
# Chain events are produced to Kafka via KAFKA_BROKERS (shared, set above).

# RPC pool tuning (all optional — shown with their defaults).
RPC_POLL_INTERVAL_MS=2000        # how often the head poller asks for the tip
RPC_HEALTH_INTERVAL_MS=10000     # how often the active health probe sweeps endpoints
RPC_REQUEST_TIMEOUT_MS=5000      # per-call ceiling; a slower call fails over
# Circuit breaker: open after N consecutive failures, stay open for the cooldown,
# then close after M half-open successes.
RPC_BREAKER_FAILURE_THRESHOLD=5
RPC_BREAKER_OPEN_COOLDOWN_MS=30000
RPC_BREAKER_SUCCESS_THRESHOLD=1


# ── Detection service (§6, §17 / Sprint 4) ─────────────────────
# The fast path: consumes BlockAssembled/BlockReverted off Kafka (KAFKA_BROKERS,
# shared above), fans each block's detectors out on rayon, and produces
# DetectorTriggered/PreliminaryAlertCreated back to Kafka. Runs on CHAIN_ID
# (shared above — one detection instance per chain).
DETECTION_KAFKA_GROUP=detection  # consumer group; restarts resume from committed offsets
# Bounded-channel depths (§17) — the inter-stage backpressure ceilings. The work
# channel holds decoded-but-not-yet-detected blocks; the commit channel holds
# published-but-not-yet-committed ones. Raise to absorb burstier input.
DETECTION_WORK_BUFFER=256
DETECTION_COMMIT_BUFFER=256
# Prometheus /metrics scrape endpoint (§19) — per-detector hit rate + latency.
# Scrape http://<host>:9100/metrics. Bind 0.0.0.0 so a scraper on the deploy
# network reaches it; narrow to 127.0.0.1 for a local-only run.
DETECTION_METRICS_ADDR=0.0.0.0:9100


# ── Observability stack (§19) ───────────────────────────────────
# Prometheus scrapes the services' /metrics (deploy/prometheus.yml); Grafana
# shows the per-detector dashboard (auto-provisioned). Start with `just metrics-up`.
# All optional — the compose defaults below apply when unset.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin


# ── JWT Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=changeme_replace_with_64_char_random_secret_do_not_use_this
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_ISSUER=mev


# ── Rate Limiting (per-tier API limits, requests/min, §11) ──────
RATE_LIMIT_CLOUD=120
RATE_LIMIT_ONPREM=300
RATE_LIMIT_ENTERPRISE=1000


# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
